@model users
@using Microsoft.Extensions.Localization
@using Microsoft.AspNetCore.Localization
@using ORM.Models.Models
@using ORM.Shared
@using static ORM.Shared.Base
@inject IStringLocalizer<APP.UI.WEB.Models.SharedResources> SharedLocalizer
@{
    ViewData["Title"] = SharedLocalizer["MyProfile"];
    Layout = "~/Views/Shared/_Layout.cshtml";
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    string culture = requestCulture.RequestCulture.Culture.Name;
}
<style>
    .borderless {
        border: none !important;
    }
</style>
<div class="card shadow-sm">
    <div class="card-header">
        <h3 class="card-title">@SharedLocalizer["MyProfile"]</h3>
        <div class="card-toolbar">

        </div>
    </div>
    <div class="card-body">
        @Html.HiddenFor(x => x.id)
        <div class="row mb-6">
            <label class="col-lg-4 col-form-label required fw-semibold fs-6">@SharedLocalizer["FullName"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">
                <input type="text" name="company" class="form-control form-control-lg form-control-solid" placeholder="@SharedLocalizer["FirstName"]" value="@Model.first_name" id="first_name">
            </div>
        </div>
        <div class="row mb-6">
            <label class="col-lg-4 col-form-label required fw-semibold fs-6">@SharedLocalizer["FullName"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">
                <input type="text" name="company" class="form-control form-control-lg form-control-solid" placeholder="@SharedLocalizer["LastName"]" value="@Model.last_name" id="last_name">
            </div>
        </div>
        <div class="row mb-6">
            <label class="col-lg-4 col-form-label  fw-semibold fs-6">@SharedLocalizer["Email"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">
                <input type="text" name="company" class="form-control form-control-lg form-control-solid" placeholder="@SharedLocalizer["Email"]" value="@Model.email" id="email">
            </div>
        </div>
        <div class="row mb-6">
            <label class="col-lg-4 col-form-label  fw-semibold fs-6">@SharedLocalizer["PhoneNo"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">
                <input type="text" name="company" class="form-control form-control-lg form-control-solid" placeholder="@SharedLocalizer["PhoneNo"]" value="@Model.phone_number" id="phone">
            </div>
        </div>
        <div class="row mb-6">
            <label class="col-lg-4 col-form-label  fw-semibold fs-6">@SharedLocalizer["Workout"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">
                <select id="workout_status" class="form-select form-select-solid" onchange="calculateDpr()">
                    <option value="@WorkoutStatus.Sendanter" selected="@(Model.workout_status == WorkoutStatus.Sendanter)">
                        @EnumExtensions.GetDisplayName(WorkoutStatus.Sendanter)
                    </option>

                    <option value="@WorkoutStatus.AzHareketli" selected="@(Model.workout_status == WorkoutStatus.AzHareketli)">
                        @EnumExtensions.GetDisplayName(WorkoutStatus.AzHareketli)
                    </option>

                    <option value="@WorkoutStatus.OrtaDereceHareketli" selected="@(Model.workout_status == WorkoutStatus.OrtaDereceHareketli)">
                        @EnumExtensions.GetDisplayName(WorkoutStatus.OrtaDereceHareketli)
                    </option>

                    <option value="@WorkoutStatus.CokHareketli" selected="@(Model.workout_status == WorkoutStatus.CokHareketli)">
                        @EnumExtensions.GetDisplayName(WorkoutStatus.CokHareketli)
                    </option>

                    <option value="@WorkoutStatus.ProfesyonelSporcu" selected="@(Model.workout_status == WorkoutStatus.ProfesyonelSporcu)">
                        @EnumExtensions.GetDisplayName(WorkoutStatus.ProfesyonelSporcu)
                    </option>
                </select>
            </div>
        </div>
        <div class="row mb-6">
            <label class="col-lg-4 col-form-label  fw-semibold fs-6">@SharedLocalizer["Height"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">
                <div class="input-group  input-group-solid mb-5">
                    <input type="text" name="company" class="form-control form-control-lg form-control-solid" placeholder="@SharedLocalizer["Height"]" value="@Model.height" id="height">
                    <span class="input-group-text" id="basic-addon2">cm</span>
                </div>


            </div>
        </div>
        <div class="row mb-6">
            <label class="col-lg-4 col-form-label  fw-semibold fs-6">@SharedLocalizer["Weight"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">
                <div class="input-group input-group-solid mb-5">
                    <input type="text" name="company" class="form-control form-control-lg form-control-solid" placeholder="@SharedLocalizer["Weight"]" value="@Model.weight" id="weight">
                    <span class="input-group-text" id="basic-addon2">kg</span>

                </div>

            </div>
        </div>
        <div class="row mb-6">
            <label class="col-lg-4 col-form-label  fw-semibold fs-6">@SharedLocalizer["TargetWeight"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">
                <div class="input-group input-group-solid mb-5">
                    <input type="text" name="company" class="form-control form-control-lg form-control-solid" placeholder="@SharedLocalizer["TargetWeight"]" value="@Model.target_weight" id="target_weight">
                    <span class="input-group-text" id="basic-addon2">kg</span>
                </div>
            </div>
        </div>

        <div class="row mb-6">
            <label class="col-lg-4 col-form-label  fw-semibold fs-6">@SharedLocalizer["Gender"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">
                <select id="gender" class="form-select form-select-solid">
                    <option value="@Gender.Kadin" selected="@(Model.gender == Gender.Kadin)">
                        @EnumExtensions.GetDisplayName(Gender.Kadin)
                    </option>

                    <option value="@Gender.Erkek" selected="@(Model.gender == Gender.Erkek)">
                        @EnumExtensions.GetDisplayName(Gender.Erkek)
                    </option>

                    <option value="@Gender.BelirtmekIstemiyor" selected="@(Model.gender == Gender.BelirtmekIstemiyor)">
                        @EnumExtensions.GetDisplayName(Gender.BelirtmekIstemiyor)
                    </option>
                </select>
            </div>
        </div>
        <div class="row mb-6">
            <label class="col-lg-4 col-form-label  fw-semibold fs-6">@SharedLocalizer["DateOfBirth"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">
                <input type="text" name="company" class="form-control form-control-lg form-control-solid date-picker" placeholder="@SharedLocalizer["DateOfBirth"]" value="@Model.date_of_birth" id="date_of_birth">
            </div>
        </div>
        <div class="row mb-6">
            <label class="col-lg-4 col-form-label  fw-semibold fs-6">@SharedLocalizer["Age"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">
                <input type="text" name="company" class="form-control form-control-lg form-control-solid" placeholder="@SharedLocalizer["Age"]" value="@Model.age" id="age">
            </div>
        </div>
        <div class="row mb-6">
            <label class="col-lg-4 col-form-label  fw-semibold fs-6">@SharedLocalizer["BMI"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">
                <div class="input-group input-group-solid mb-5">
                    <input type="text" name="company" class="form-control form-control-lg form-control-solid" placeholder="@SharedLocalizer["BMI"]" value="@Model.bmi" id="bmi">
                    <span class="input-group-text" id="basic-addon1">kcal</span>

                </div>

            </div>
        </div>
        <div class="row mb-6">
            <label class="col-lg-4 col-form-label  fw-semibold fs-6">@SharedLocalizer["BMR"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">
                <input type="text" name="company" class="form-control form-control-lg form-control-solid" placeholder="@SharedLocalizer["BMR"]" value="@Model.bmr" id="bmr">
            </div>
        </div>
        <div class="row mb-6">
            <label class="col-lg-4 col-form-label  fw-semibold fs-6">@SharedLocalizer["TDEE"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">
                <div class="input-group input-group-solid mb-5">
                    <input type="text" name="company" class="form-control form-control-lg form-control-solid" placeholder="@SharedLocalizer["TDEE"]" value="@Model.tdee" id="tdee">
                    <span class="input-group-text" id="basic-addon1">kcal</span>
                </div>
            </div>
        </div>
        <div class="row mb-6">
            <label class="col-lg-4 col-form-label  fw-semibold fs-6">@SharedLocalizer["DPR"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">
                <div class="input-group input-group-solid mb-5">
                    <input type="text" name="company" class="form-control form-control-lg form-control-solid" placeholder="@SharedLocalizer["DPR"]" value="@Model.dpr" id="dpr">
                    <span class="input-group-text" id="basic-addon1">g</span>
                </div>
            </div>
        </div>
        <div class="row mb-6">
            <label class="col-lg-4 col-form-label  fw-semibold fs-6">@SharedLocalizer["CalculationUpdate"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">
                <input class="form-check-input" type="checkbox" value="" id="is_calculation_update" checked />
                <label class="form-check-label" for="is_calculation_update">
                    @SharedLocalizer["CalculationUpdate"]
                </label>
            </div>
        </div>
        <div class="row mb-6">
            <label class="col-lg-4 col-form-label  fw-semibold fs-6">@SharedLocalizer["CurrentPwd"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">
                <div class="input-group mb-5">
                    <input type="password" class="form-control form-control-lg form-control-solid" placeholder="@SharedLocalizer["CurrentPwd"]" aria-label="@SharedLocalizer["CurrentPwd"]" aria-describedby="basic-addon2" id="current_pwd">
                    <span class="input-group-text borderless" id="basic-addon2">
                        <i class="fa fa-eye" style="cursor:pointer;" id="current" onclick="show('current_pwd')"></i>
                    </span>
                </div>
            </div>
        </div>
        <div class="row mb-6">
            <label class="col-lg-4 col-form-label  fw-semibold fs-6">@SharedLocalizer["NewPwd"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">

                <div class="input-group mb-5">
                    <input type="password" class="form-control form-control-lg form-control-solid" placeholder="@SharedLocalizer["NewPwd"]" aria-label="@SharedLocalizer["NewPwd"]" aria-describedby="basic-addon2" id="new_pwd">
                    <span class="input-group-text borderless" id="basic-addon2">
                        <i class="fa fa-eye" style="cursor:pointer;" id="new" onclick="show('new_pwd')"></i>
                    </span>
                </div>
            </div>
        </div>
        <div class="row mb-6">
            <label class="col-lg-4 col-form-label  fw-semibold fs-6">@SharedLocalizer["RenewPwd"]</label>
            <div class="col-lg-8 fv-row fv-plugins-icon-container">
                <div class="input-group mb-5">
                    <input type="password" class="form-control form-control-lg form-control-solid" placeholder="@SharedLocalizer["RenewPwd"]" aria-label="@SharedLocalizer["RenewPwd"]" aria-describedby="basic-addon2" id="renew_pwd">
                    <span class="input-group-text borderless" id="basic-addon2">
                        <i class="fa fa-eye-slash" style="cursor:pointer;" id="renew" onclick="show('renew_pwd')"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="card-footer d-flex justify-content-end py-6 px-9">
        <button type="button" class="btn btn-primary" onclick="save()">@SharedLocalizer["SaveChanges"]</button>
    </div>
</div>
<script>
    $(document).ready(function () {
        Inputmask({
            "mask": "(999) 999-9999"
        }).mask(".phone-mask");
        Inputmask({
            mask: "*{1,20}[.*{1,20}][.*{1,20}][.*{1,20}]@@*{1,20}[.*{2,6}][.*{1,2}]",
            greedy: false,
            onBeforePaste: function (pastedValue, opts) {
                pastedValue = pastedValue.toLowerCase();
                return pastedValue.replace("mailto:", "");
            },
            definitions: {
                "*": {
                    validator: '[0-9A-Za-z!#$%&"*+/=?^_`{|}~\-]',
                    cardinality: 1,
                    casing: "lower"
                }
            }
        }).mask(".email-mask");
        $(".date-picker").flatpickr({
            dateFormat: "d.m.Y",
            onChange: function (selectedDates, dateStr, instance) {
                calculateAge();
            },
            locale: {
                weekdays: {
                    shorthand: ["Pzt", "Sal", "Çar", "Per", "Cum", "Cts", "Paz"],
                    longhand: [
                        "Pazartesi",
                        "Salı",
                        "Çarşamba",
                        "Perşembe",
                        "Cuma",
                        "Cumartesi",
                        "Pazar"
                    ]
                },
                months: {
                    shorthand: [
                        "Oca", "Şub", "Mar", "Nis", "May", "Haz",
                        "Tem", "Ağu", "Eyl", "Eki", "Kas", "Ara"
                    ],
                    longhand: [
                        "Ocak",
                        "Şubat",
                        "Mart",
                        "Nisan",
                        "Mayıs",
                        "Haziran",
                        "Temmuz",
                        "Ağustos",
                        "Eylül",
                        "Ekim",
                        "Kasım",
                        "Aralık"
                    ]
                },
                firstDayOfWeek: 1
            }
        });
    });
    $("#bmr").on("input", function () {
        let bmr = parseFloat($(this).val());
        if (!isNaN(bmr)) {
            calculateTdee(bmr);
        }
    });
    $("#weight").on("input", function () {
        let weight = parseFloat($(this).val());

        if (!isNaN(weight)) {
            calculateDpr(weight);
        }
    });
    function show(id) {
        var iconId = id.split('_')[0];
        const input = document.getElementById(id);
        if (input.type === "password") {
            document.getElementById(iconId).className = "fa fa-eye-slash";
            input.type = "text";
        } else {
            document.getElementById(iconId).className = "fa fa-eye";
            input.type = "password";
        }
    }
    function calculateAge() {
        var dateOfBirth = new Date($("#date_of_birth").val());
        var today = new Date();
        var age = today.getFullYear() - dateOfBirth.getFullYear();
        var monthDifference = today.getMonth() - dateOfBirth.getMonth();
        if (monthDifference < 0 || (monthDifference === 0 && today.getDate() < dateOfBirth.getDate())) {
            age--;
        }
        $("#age").val(age);
    }
    function calculateTdee(bmr) {
        var workout_status = $("#workout_status").val();
        let tdee;
        if (workout_status === "AzHareketli") {
            tdee = bmr * 1.375;
        }
        else if (workout_status === "OrtaDereceHareketli") {
            tdee = bmr * 1.55;
        }
        else if (workout_status === "CokHareketli") {
            tdee = bmr * 1.725;
        }
        else if (workout_status === "ProfesyonelSporcu") {
            tdee = bmr * 1.9;
        }
        else {
            tdee = bmr * 1.2;
        }
        $("#tdee").val(tdee);
    }
    function calculateDpr(weight) {
        var workout_status = $("#workout_status").val();
        let dpr;
        if (workout_status === "AzHareketli") {
            dpr = weight * 1.3;
        }
        else if (workout_status === "OrtaDereceHareketli") {
            dpr = weight * 1.5;
        }
        else if (workout_status === "CokHareketli") {
            dpr = weight * 1.8;
        }
        else if (workout_status === "ProfesyonelSporcu") {
            dpr = weight * 2.2;
        }
        else {
            dpr = weight * 0.9;
        }
        $("#dpr").val(dpr.toFixed(1));
    }
    function calculateDpr() {
        let weight = parseFloat($("#weight").val());
        var workout_status = $("#workout_status").val();
        let dpr;
        if (workout_status === "AzHareketli") {
            dpr = weight * 1.3;
        }
        else if (workout_status === "OrtaDereceHareketli") {
            dpr = weight * 1.5;
        }
        else if (workout_status === "CokHareketli") {
            dpr = weight * 1.8;
        }
        else if (workout_status === "ProfesyonelSporcu") {
            dpr = weight * 2.2;
        }
        else {
            dpr = weight * 0.9;
        }
        $("#dpr").val(dpr.toFixed(1));
    }
    function save() {
        var id = $("#id").val();
        var first_name = $("#first_name").val();
        var last_name = $("#last_name").val();
        var email = $("#email").val();
        var phone = $("#phone").val();
        var height = $("#height").val();
        var weight = $("#weight").val();
        var date_of_birth = $("#date_of_birth").val();
        var target_weight = $("#target_weight").val();
        var workout_status = $("#workout_status").val();
        var gender = $("#gender").val();
        var age = $("#age").val();
        var bmi = $("#bmi").val();
        var bmr = $("#bmr").val();
        var tdee = $("#tdee").val();
        var dpr = $("#dpr").val();
        var current_pwd = $("#current_pwd").val();
        var new_pwd = $("#new_pwd").val();
        var renew_pwd = $("#renew_pwd").val();
        var is_calculation_update = $("#is_calculation_update").is(":checked");
        if (first_name != '' && last_name != '') {
            if (new_pwd == renew_pwd) {
                debugger;
                $.post("/Account/Save", { id: id, first_name: first_name, last_name: last_name, email: email, phone: phone, height: height, weight: weight, date_of_birth: date_of_birth, target_weight: target_weight, workout_status: workout_status, gender: gender, age: age, bmi: bmi, bmr: bmr, tdee: tdee, dpr: dpr, current_pwd: current_pwd, new_pwd: new_pwd, is_calculation_update: is_calculation_update },
                    function (data, textStatus, jqXHR) {
                        debugger;
                        if (data.success) {
                            toastr.success(data.message);
                            window.location.reload();
                        } else {
                            toastr.error(data.message);
                        }
                    }
                );
            } else {
                toastr.warning("Şifreler aynı olmalıdır.");
            }
        } else {
            toastr.warning("Yıldızlı alanlar zorunludur.");
        }


    }
</script>
