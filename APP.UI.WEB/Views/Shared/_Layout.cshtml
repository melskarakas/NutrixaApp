@    using Microsoft.AspNetCore.Http;
@    using System.Text.Json;
@    using Microsoft.Extensions.Localization
@    using Microsoft.AspNetCore.Localization
@    using ORM.Models;
    using ORM.Models.Models
@inject IStringLocalizer<APP.UI.WEB.Models.SharedResources> SharedLocalizer
@inject IHttpContextAccessor HttpContextAccessor
@{
    Layout = null;

    //Operations.LogErisimEkle(HttpContext.Request);
    string jsonStr = HttpContextAccessor.HttpContext.Session.GetString("AKTIF_KULLANICI");
    users user = JsonSerializer.Deserialize<users>(jsonStr);
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    string culture = requestCulture.RequestCulture.Culture.Name;

    var returnUrl = string.IsNullOrEmpty(Context.Request.Path) ? "~/" : $"~{Context.Request.Path.Value}";
    var queryStr = string.IsNullOrEmpty(Context.Request.QueryString.Value) ? "" : Context.Request.QueryString.Value;
    returnUrl += queryStr;

}

